# --- The "Let Me Use Tabs" Rules ---
-no-tabs
-line-length=length:100  # Default is often 80; 100 or 120 is more modern

# --- The "Don't Be So Anal" Rules ---
-no-trailing-spaces      # Because who cares about invisible spaces?
-posix-eof               # Stops nagging about the newline at the end of the file
#-parameter-name-style    # Stops forcing SCREAMING_SNAKE_CASE
#-signal-name-style       # Stops forcing camelCase or snake_case styles
#-module-filename         # Stops complaining if module name != filename
#-package-filename        # Same for packages

# --- Logic & Style "Chill" Rules ---
#-packed-dimensions-range-order # Allows [0:7] if you really want it (default is [7:0])
#-unpacked-dimensions-range-order
#-invalid-system-task-function  # Stops nagging about $display vs $info